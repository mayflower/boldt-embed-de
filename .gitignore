# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/

# Secrets / env
.env
*.key

# Model weights & large binary artifacts (never commit)
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx
*.gguf
checkpoints/
wandb/

# Raw / cached datasets (only small toy samples under data/samples are tracked)
data/raw/
data/cache/
data/processed/

# Large eval artifacts (small json/md reports under outputs/ ARE tracked)
outputs/**/*.npy
outputs/**/*.parquet
outputs/**/*.arrow
mteb_results/

# Generated teacher score caches (never committed; can be many GB of JSONL)
outputs/teacher-cache/

.DS_Store

# v2 run: large intermediate data + teacher-cache shards (keep small *.json summaries/reports)
outputs/**/teacher-cache/*.jsonl
outputs/v2-generalization/*.jsonl
outputs/v2-generalization/*.log

# v3 run: large intermediate data (keep small *.json/*.md reports + run cards)
outputs/v3-real-domain/*.jsonl
outputs/v3-real-domain/*.log
outputs/v3-real-domain/leakage/*.jsonl
outputs/v3-real-domain/leakage/eval_index.json
outputs/v3-real-domain/bm25_v3.json

# v4 RAG reranker run: large intermediate data (weights via *.safetensors/checkpoints/ above).
# Small json/md summaries, gate, lift reports, run card, and *.report.json ARE tracked.
outputs/v4-rag-reranker/*.log
outputs/v4-rag-reranker/**/*.jsonl
outputs/v4-rag-reranker/first_stage/*.json
outputs/v4-rag-reranker/teacher/rag_teacher_summary.json

# v5 small-RAG run: large intermediate data (weights via *.safetensors/checkpoints/ above).
# Small json/md summaries (V5_RESULTS, gate, *.report.json, teacher summary), run cards,
# COMMANDS.md and STATUS.json ARE tracked. Raw data + scored/candidate JSONL are NOT.
outputs/v5-small-rag/**/*.log
outputs/v5-small-rag/**/*.jsonl
outputs/v5-small-rag/train/bm25.json
outputs/v5-small-rag/train/domain_map.json
outputs/v5-small-rag/v5-reranker-boldt_run_card.json
data/raw/v5/*.jsonl

# v6 candidate union lists (large data artifacts; reports stay tracked)
*_candidate_union.jsonl
reranker_train_union_lists.jsonl

# proxy/full dense candidate dumps (large data artifacts)
*_dense_v6_candidates.jsonl

# AutoResearch loop: heavy run directories + checkpoints are generated, never committed.
# The audit log (outputs/autoresearch/results.tsv) and committed baselines under
# outputs/autoresearch/baseline/ ARE tracked.
outputs/autoresearch/runs/
outputs/autoresearch/checkpoints/

# v7 EmbedFilter: SVD basis tensors are large binaries (also covered by the global *.pt rule);
# the small metadata.json sidecars + sweep reports under outputs/v7-embedfilter/ ARE tracked.
outputs/embedfilter/**/*.pt

# AutoResearch prepared data: large generated candidate/clean training JSONL are local working
# files (regenerable from the leakage scan); the small reports + manifest under prepared/ ARE tracked.
outputs/autoresearch/prepared/*.jsonl

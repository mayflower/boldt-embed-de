{
  "name": "v8_frontier_program",
  "description": "Trial-type defaults the AutoResearch controller turns into plans. Each entry names the orchestration script + its config + output location. The controller only PLANS these (prints the command); real GPU work is launched by running the trial script itself with explicit flags.",
  "trials": {
    "data_mix": {
      "script": "scripts/ar_build_mixture.py",
      "config": "configs/autoresearch/mixtures/v8_balanced.json",
      "catalog": "configs/data_sources.json",
      "out": "outputs/autoresearch/mixtures/v8_balanced",
      "produces": ["outputs/autoresearch/mixtures/v8_balanced/train.jsonl", "outputs/autoresearch/mixtures/v8_balanced/manifest.json"],
      "real_flags": []
    },
    "dense": {
      "script": "scripts/ar_loop.py",
      "config": "configs/autoresearch/experiments/current.json",
      "produces": ["outputs/autoresearch/runs/<run_id>/checkpoint"],
      "real_flags": ["--real", "--allow-gpu", "--allow-checkpoints"]
    },
    "hardneg_refresh": {
      "script": "scripts/ar_refresh_hardnegatives.py",
      "config": "configs/autoresearch/hardneg_refresh.json",
      "out": "outputs/autoresearch/hardneg/v8_refresh_001",
      "produces": ["outputs/autoresearch/hardneg/v8_refresh_001/hardnegatives.jsonl", "outputs/autoresearch/hardneg/v8_refresh_001/listwise_candidates.jsonl"],
      "real_flags": ["--real", "--allow-gpu", "--allow-teacher"]
    },
    "specialist": {
      "script": "scripts/ar_train_specialist.py",
      "config": "configs/autoresearch/specialists/v8_specialists.json",
      "out_root": "outputs/v8/specialists",
      "produces": ["outputs/v8/specialists/spec-<label>/checkpoint"],
      "real_flags": ["--real", "--allow-gpu", "--allow-checkpoints"]
    },
    "merge": {
      "script": "scripts/ar_merge_search.py",
      "config": "configs/autoresearch/merge_search_v8.json",
      "out": "outputs/merged/v8_merge_search",
      "produces": ["outputs/merged/v8_merge_search/<method>/checkpoint"],
      "real_flags": ["--real", "--allow-merge"]
    },
    "distill": {
      "script": "scripts/ar_distill_trial.py",
      "config": "configs/autoresearch/distill/listwise_kl_v8.json",
      "produces": ["outputs/v8/distill/<name>/checkpoint"],
      "real_flags": ["--real", "--allow-gpu", "--allow-checkpoints"]
    },
    "mteb": {
      "script": "scripts/ar_mteb_trial.py",
      "config": "configs/autoresearch/mteb_retrieval_core.json",
      "produces": ["outputs/mteb/<label>/summary.json"],
      "real_flags": ["--real", "--allow-gpu"]
    },
    "promotion": {
      "script": "scripts/ar_promote.py",
      "config": "configs/autoresearch/mteb_retrieval_core.json",
      "produces": ["outputs/autoresearch/mteb/<label>/promotion_verdict.json"],
      "real_flags": []
    }
  }
}

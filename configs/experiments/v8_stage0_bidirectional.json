{
  "experiment": "v8c",
  "stage": 0,
  "title": "bidirectional conversion + retrain (LLM2Vec mask patch)",
  "doc": "docs/v8-improvement-research-2026.md",
  "base_model": "outputs/v6-dense-rag/checkpoints/boldt-dense-rag-v6",
  "bidirectional": true,
  "mntp": false,
  "pooling": "mean",
  "train_pairs": "outputs/autoresearch/prepared/train_candidates.clean.jsonl",
  "hard_negatives": "data/processed/v6_1/dense_top50_hardnegatives.jsonl",
  "matryoshka_dims": [1024, 768, 512, 256, 128, 64],
  "training": {
    "max_steps": 300,
    "batch_size": 32,
    "max_seq_length": 256,
    "learning_rate": 1e-05,
    "warmup_ratio": 0.05,
    "temperature": 0.05,
    "bf16": true
  },
  "eval": {
    "harness": "scripts/run_mteb_retrieval_de.py",
    "bidirectional_patch_required": true,
    "tasks": ["GermanQuAD-Retrieval", "GerDaLIRSmall", "MIRACLRetrievalHardNegatives", "MultiLongDocRetrieval"],
    "max_seq_length": 512,
    "gate": "scripts/check_v8_gate.py --candidate v8-stage0-bi --baseline v6-1-baseline --require-bidirectional"
  },
  "notes": [
    "Bidirectional patch is a RUNTIME modification (not saved in weights); eval re-applies it via the runner --bidirectional flag and eager attention.",
    "Stage 0 is the architecture A/B vs causal round-7@512 (0.866/0.085/0.326/0.221).",
    "Stages 1 (broad weak pretrain) and 2 (listwise-KL supervised FT) build on the Stage-0 bidirectional checkpoint."
  ]
}
